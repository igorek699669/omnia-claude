# Скопируйте в .env.local и заполните реальными значениями. .env.local в git не попадает.

# Postgres (Better Auth хранит там users/sessions/verification в схеме public;
# Payload хранит свои таблицы в отдельной схеме payload — см. payload/payload.config.ts)
DATABASE_URL=postgres://user:password@localhost:5432/omnia

# Секрет для подписи сессий Better Auth — сгенерировать: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Адрес, на котором крутится приложение
BETTER_AUTH_URL=http://localhost:3000

# Секрет Payload CMS (шифрование сессий админки/сериализация) — сгенерировать так же: openssl rand -base64 32
PAYLOAD_SECRET=

# SMTP для отправки кода подтверждения на email
SMTP_HOST=
SMTP_PORT=587
# true для порта 465, false для 587/25
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Omnia <noreply@omnia.ru>"
